# Configuração do Lector Playbook Converter

# Diretórios
INPUT_DIR=C:\Users\Lector\Desktop\Documentações
OUTPUT_DIR=C:\Users\Lector\lector-playbook-converter\output

# Configurações de Modelo (deixe em branco para usar com API key)
ANTHROPIC_API_KEY=
MODEL=claude-3-sonnet-20240229

# Identidade Visual Lector - EXTRAÍDA DO SITE www.lector.com.br
# Baseado em análise do screenshot fornecido
LECTOR_PRIMARY_COLOR=#1E3A5F        # Azul escuro do header
LECTOR_SECONDARY_COLOR=#2563EB     # Azul brilhante (botões, links)
LECTOR_ACCENT_COLOR=#D97757        # Laranja/Coral (CTAs, alertas)
LECTOR_BACKGROUND_COLOR=#FFFFFF    # Branco (backgrounds)
LECTOR_TEXT_COLOR=#2D3748          # Cinza escuro (texto principal)
LECTOR_FONT_HEADING=Calibri         # Fonte de títulos
LECTOR_FONT_BODY=Calibri            # Fonte de corpo

# Configurações de processamento
MAX_WORKERS=3
PRESERVE_IMAGES=true
DEBUG=false
