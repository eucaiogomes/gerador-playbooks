# Configuração do Lector Playbook Converter
# Copie este arquivo para .env e ajuste os valores

# Diretórios
INPUT_DIR=C:\Users\Lector\Desktop\Documentações
OUTPUT_DIR=C:\Users\Lector\lector-playbook-converter\output

# Configurações de Modelo (usando Claude via API Anthropic)
# Ou deixe em branco para usar modelos locais/free
ANTHROPIC_API_KEY=sua_chave_aqui
MODEL=claude-3-sonnet-20240229

# Identidade Visual Lector (preencha com as cores do site)
LECTOR_PRIMARY_COLOR=#2E5BFF
LECTOR_SECONDARY_COLOR=#00C9A7
LECTOR_ACCENT_COLOR=#FF6B6B
LECTOR_BACKGROUND_COLOR=#FFFFFF
LECTOR_TEXT_COLOR=#1A1A2E
LECTOR_FONT_HEADING=Montserrat
LECTOR_FONT_BODY=Open Sans

# Configurações de processamento
MAX_WORKERS=3
PRESERVE_IMAGES=true
DEBUG=false
